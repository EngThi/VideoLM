{
  "name": "youtubevideomaster-ai-pipeline",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port ${PORT:-5173} --host\" \"npm run server:dev\"",
    "build": "npm run server:build && vite build",
    "preview": "vite preview",
    "server:install": "cd server && npm install",
    "server:dev": "cd server && PORT=3001 npm run dev",
    "server:build": "cd server && npm run build",
    "server:start": "cd server && npm run start:prod",
    "postinstall": "npm run server:install",
    "test": "cd server && npm test"
  },
  "dependencies": {
    "@google/genai": "^1.19.0",
    "dom": "^0.0.3",
    "esbuild": "^0.27.2",
    "jszip": "3.10.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.19.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
