# API keys
GEMINI_API_KEY=replace-with-your-gemini-key
OPENROUTER_API_KEY=replace-with-your-openrouter-key
HF_TOKENS=token1,token2,token3

# App security
JWT_SECRET=replace-with-a-long-random-secret

# Public URL used by /api/engine/manifest
PUBLIC_BASE_URL=https://54-162-84-165.sslip.io

# Database
# Docker uses /app/server/data/database.sqlite internally.
DATABASE_PATH=./server/data/database.sqlite

# NotebookLM
# Install the upstream CLI:
#   uv tool install notebooklm-mcp-cli
#
# Log in on the host:
#   nlm login
#   nlm login --check
#   nlm doctor
#
# Default cookie path:
#   ~/.notebooklm-mcp-cli/profiles/default/cookies.json
#
# Production Docker mount:
NLM_HOME=/home/ubuntu/.notebooklm-mcp-cli
